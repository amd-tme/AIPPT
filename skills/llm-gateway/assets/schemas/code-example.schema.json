{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LLM Gateway Code Example",
  "description": "Structured code example for AMD LLM Gateway usage",
  "type": "object",
  "required": ["model", "provider", "sdk", "code"],
  "properties": {
    "model": {
      "type": "string",
      "description": "Model name (e.g., claude-sonnet-4-5@20250929)"
    },
    "provider": {
      "type": "string",
      "enum": ["vertex_ai", "azure_openai", "onprem"],
      "description": "Cloud provider for the model"
    },
    "sdk": {
      "type": "string",
      "enum": ["anthropic", "openai", "google-generativeai"],
      "description": "Python SDK to use"
    },
    "endpoint": {
      "type": "string",
      "description": "AMD Gateway endpoint URL"
    },
    "code": {
      "type": "object",
      "properties": {
        "setup": {
          "type": "string",
          "description": "pip install command"
        },
        "environment": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Required environment variables"
        },
        "basic": {
          "type": "string",
          "description": "Basic usage code example"
        },
        "advanced": {
          "type": "string",
          "description": "Advanced usage with streaming/tools"
        }
      },
      "required": ["setup", "basic"]
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["chat", "streaming", "tool_use", "vision", "embeddings"]
      },
      "description": "Model capabilities"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Important notes about using this model"
    }
  }
}
